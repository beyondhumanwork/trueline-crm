# Cron
CRON_SECRET=your-secret-here

# Email (Resend)
RESEND_API_KEY=re_your-api-key-here

# ElectricSQL Sync
ELECTRIC_DATABASE_URL=postgresql://user:password@host:5432/dbname
ELECTRIC_JWT_SECRET=your-jwt-secret
